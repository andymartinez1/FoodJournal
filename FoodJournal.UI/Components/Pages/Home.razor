@page "/"

<PageTitle>Home</PageTitle>

<div class="home-container">
    <div class="welcome-hero">
        <div class="welcome-text">
            <h1>Food Journal</h1>
            <p>Track your meals and discover your eating patterns</p>
        </div>
        <div class="quick-actions">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Add" Class="action-btn">
                New Food Item
            </MudButton>
            <MudButton Variant="Variant.Outlined" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.DinnerDining" Class="action-btn action-btn-outline">
                New Meal
            </MudButton>
        </div>
    </div>

    <div class="stats-section">
        <div class="stat-card stat-blue">
            <div class="stat-icon">
                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Style="font-size:2rem;"/>
            </div>
            <div class="stat-value">24</div>
            <div class="stat-label">Meals This Week</div>
        </div>
        <div class="stat-card stat-pink">
            <div class="stat-icon">
                <MudIcon Icon="@Icons.Material.Filled.Favorite" Style="font-size:2rem;"/>
            </div>
            <div class="stat-value">12</div>
            <div class="stat-label">Favorite Meals</div>
        </div>
        <div class="stat-card stat-green">
            <div class="stat-icon">
                <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="font-size:2rem;"/>
            </div>
            <div class="stat-value">156</div>
            <div class="stat-label">Total Items Logged</div>
        </div>
    </div>

    <h2 class="section-title">Your Favorite Meals</h2>
    <div class="meals-grid">
        <div class="meal-card">
            <MudIconButton Class="fav-btn fav-active" Icon="@Icons.Material.Filled.Favorite" Size="Size.Small"/>
            <div class="meal-info">
                <div class="meal-name">Grilled Salmon</div>
                <div class="meal-times">Eaten 8 times</div>
                <div class="meal-frequency">Last eaten: 2 days ago</div>
            </div>
            <div class="meal-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="meal-btn">View
                </MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Class="meal-btn">Edit</MudButton>
            </div>
        </div>

        <div class="meal-card">
            <MudIconButton Class="fav-btn" Icon="@Icons.Material.Outlined.FavoriteBorder" Size="Size.Small"/>
            <div class="meal-info">
                <div class="meal-name">Caesar Salad</div>
                <div class="meal-times">Eaten 5 times</div>
                <div class="meal-frequency">Last eaten: 1 week ago</div>
            </div>
            <div class="meal-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="meal-btn">View
                </MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Class="meal-btn">Edit</MudButton>
            </div>
        </div>

        <div class="meal-card">
            <MudIconButton Class="fav-btn fav-active" Icon="@Icons.Material.Filled.Favorite" Size="Size.Small"/>
            <div class="meal-info">
                <div class="meal-name">Spaghetti</div>
                <div class="meal-times">Eaten 12 times</div>
                <div class="meal-frequency">Last eaten: Today</div>
            </div>
            <div class="meal-actions">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="meal-btn">View
                </MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Class="meal-btn">Edit</MudButton>
            </div>
        </div>
    </div>

    <h2 class="section-title">Recent Entries</h2>
    <div class="recent-list">
        @foreach (var entry in recentEntries)
        {
            <div class="recent-item">
                <div class="recent-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Restaurant" Style="color:#ff9800;"/>
                </div>
                <div class="recent-details">
                    <div class="recent-name">@entry.Name</div>
                    <div class="recent-date">@entry.Date.ToString("MMM d, yyyy · h:mm tt")</div>
                </div>
                <div class="recent-actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="recent-action-btn"/>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Class="recent-action-btn"/>
                </div>
            </div>
        }
    </div>
</div>


@code {
    private List<RecentEntry> recentEntries = new();

    protected override void OnInitialized()
    {
        recentEntries = new List<RecentEntry>
        {
            new() { Name = "Chicken Breast", Date = DateTime.Now },
            new() { Name = "Brown Rice", Date = DateTime.Now.AddHours(-2) },
            new() { Name = "Broccoli", Date = DateTime.Now.AddDays(-1) }
        };
    }

    public class RecentEntry
    {
        public string Name { get; set; }
        public DateTime Date { get; set; }
    }

}