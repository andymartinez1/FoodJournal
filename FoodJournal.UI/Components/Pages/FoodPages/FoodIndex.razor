@page "/foods"
@inject IFoodService FoodService
@inject IReportService ReportService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Food</PageTitle>

<div class="foods-page">
    <div class="page-header">
        <div>
            <h1 class="page-title">Foods</h1>
            <p class="page-subtitle">Manage your food item library</p>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Class="add-btn"
                   OnClick="Create">
            Add Food
        </MudButton>
    </div>

    <div class="filter-bar">
        <MudTextField T="string" Value="@NameSearch"
                      ValueChanged="@(v => OnSearchChanged(nameof(NameSearch), v))"
                      ValueExpression="(() => NameSearch)"
                      Placeholder="Search by name..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Class="search-field"/>
        <MudTextField T="string" Value="@CategorySearch"
                      ValueChanged="@(v => OnSearchChanged(nameof(CategorySearch), v))"
                      ValueExpression="(() => CategorySearch)"
                      Placeholder="Filter by category..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Category"
                      Immediate="true"
                      Class="search-field"/>
        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.FilterAltOff"
                   OnClick="@ClearFilters"
                   Class="filter-btn">
            Clear
        </MudButton>
    </div>

    <div class="table-wrap">
        <MudTable Items="@_filteredFoods" Hover="true" Breakpoint="Breakpoint.Sm"
                  LoadingProgressColor="Color.Info" Elevation="0" Class="foods-table">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Category</MudTh>
                <MudTh Style="text-align:center">Calories</MudTh>
                <MudTh Style="text-align:center">Protein (g)</MudTh>
                <MudTh Style="text-align:center">Fat (g)</MudTh>
                <MudTh Style="text-align:center">Carbs (g)</MudTh>
                <MudTh Style="text-align:right">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudLink Underline="Underline.None" Class="food-name-link"
                             OnClick="@(() => Details(context.FoodId))">
                        @context.Name
                    </MudLink>
                </MudTd>
                <MudTd DataLabel="Category">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="Color.Primary" Class="category-chip">
                        @context.Category
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Calories" Style="text-align:center">
                    <span class="nutrient-badge cal">@context.Calories</span>
                </MudTd>
                <MudTd DataLabel="Protein" Style="text-align:center">
                    <span class="nutrient-badge prot">@context.Protein</span>
                </MudTd>
                <MudTd DataLabel="Fat" Style="text-align:center">
                    <span class="nutrient-badge fat">@context.Fat</span>
                </MudTd>
                <MudTd DataLabel="Carbs" Style="text-align:center">
                    <span class="nutrient-badge carb">@context.Carbs</span>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align:right">
                    <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                   Size="Size.Small" Class="action-icon-btn edit-btn"
                                   OnClick="@(() => Edit(context.FoodId))"/>
                    <MudIconButton Icon="@Icons.Material.Outlined.DeleteOutline"
                                   Size="Size.Small" Class="action-icon-btn delete-btn"
                                   OnClick="@(() => Delete(context.FoodId))"/>
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager/>
            </PagerContent>
        </MudTable>
    </div>
</div>

@code {
    public string NameSearch { get; set; } = "";
    public string CategorySearch { get; set; } = "";

    private List<FoodResponse> _foods = new();
    private List<FoodResponse> _filteredFoods = new();

    protected override async Task OnInitializedAsync()
    {
        _foods = await LoadFoodItems();
        _filteredFoods = _foods;
    }

    private async Task<List<FoodResponse>> LoadFoodItems()
    {
        return await FoodService.GetAllAsync();
    }

    private void OnSearchChanged(string searchBy, string value)
    {
        if (searchBy == nameof(NameSearch)) NameSearch = value;
        else if (searchBy == nameof(CategorySearch)) CategorySearch = value;
        FilterItems();
        StateHasChanged();
    }

    private void FilterItems()
    {
        _filteredFoods = _foods
            .Where(f => string.IsNullOrWhiteSpace(NameSearch) ||
                        f.Name.Contains(NameSearch, StringComparison.OrdinalIgnoreCase))
            .Where(f => string.IsNullOrWhiteSpace(CategorySearch) ||
                        (f.Category ?? string.Empty).Contains(CategorySearch, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void ClearFilters()
    {
        NameSearch = string.Empty;
        CategorySearch = string.Empty;
        FilterItems();
        StateHasChanged();
    }

    private void Create()
    {
        NavigationManager.NavigateTo("/foods/create");
    }

    private async Task Details(int foodId)
    {
        await ReportService.LogFoodConsumptionAsync(foodId, DateOnly.FromDateTime(DateTime.Today));

        var food = await FoodService.GetByIdAsync(foodId);

        var parameters = new DialogParameters<FoodDetailsDialogComponent> { { "Food", food } };
        var dialog = await DialogService.ShowAsync<FoodDetailsDialogComponent>("Details", parameters);
        var result = await dialog.Result;
    }

    private void Edit(int foodId)
    {
        NavigationManager.NavigateTo($"/foods/edit/{foodId}");
    }

    private async Task Delete(int foodId)
    {
        var food = await FoodService.GetByIdAsync(foodId);

        var parameters = new DialogParameters<DeleteFoodDialogComponent> { { "Food", food } };
        var dialog = await DialogService.ShowAsync<DeleteFoodDialogComponent>("Delete", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await FoodService.DeleteAsync(foodId);
            Snackbar.Add($"{food.Name} deleted successfully!", Severity.Success);

            _foods = await LoadFoodItems();
            FilterItems();
            await InvokeAsync(StateHasChanged);
        }
    }

}
