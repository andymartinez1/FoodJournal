@page "/foods/edit/{FoodId:int}"
@inject IFoodService FoodService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>

@if (_notFound)
{
    <p>Food not found.</p>
}
else
{
    <EditForm Model="Food" OnValidSubmit="UpdateFood">
        <DataAnnotationsValidator/>

        <MudGrid>
            <MudItem xs="12" sm="7">
                <MudCard>
                    <MudCardContent>
                        <MudTextField Label="Food name"
                                      @bind-Value="Food.Name"
                                      For="@(() => Food.Name)"/>

                        <MudSelect T="string"
                                   Label="Category"
                                   @bind-Value="Food.Category"
                                   For="@(() => Food.Category)"
                                   Searchable="true"
                                   Clearable="true">
                            @foreach (var category in _existingCategories)
                            {
                                <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="int" Label="Appears in meals" Class="mt-3" MultiSelection="true"
                                   SelectedValues="_selectedMealIds" SelectedValuesChanged="OnSelectedMealsChanged">
                            @foreach (var m in _meals)
                            {
                                <MudSelectItem Value="@m.MealId">@m.Name (@m.MealType)</MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField Label="Calories" Class="mt-3"
                                      @bind-Value="Food.Calories"
                                      For="@(() => Food.Calories)"/>
                        <MudTextField Label="Protein(g)" Class="mt-3"
                                      @bind-Value="Food.Protein"
                                      For="@(() => Food.Protein)"/>
                        <MudTextField Label="Fat(g)" Class="mt-3"
                                      @bind-Value="Food.Fat"
                                      For="@(() => Food.Fat)"/>
                        <MudTextField Label="Carbs(g)" Class="mt-3"
                                      @bind-Value="Food.Carbs"
                                      For="@(() => Food.Carbs)"/>
                    </MudCardContent>

                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                   Class="ml-auto" OnClick="@Home">
                            Cancel
                        </MudButton>

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled" Color="Color.Primary"
                                   Class="ml-auto">
                            Submit
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>
}

@code {
    [Parameter] public int FoodId { get; set; }
    private IEnumerable<int> _selectedMealIds = Enumerable.Empty<int>();
    private List<Meal> _meals = new();
    private bool _notFound;
    private List<string> _existingCategories = new();
    private UpdateFoodRequest Food { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        _meals = await FoodService.GetAllMealsAsync();

        var foods = await FoodService.GetAllFoodAsync();
        _existingCategories = foods
            .Select(f => f.Category)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c)
            .ToList()!;
    }

    protected override async Task OnParametersSetAsync()
    {
        _notFound = false;

        var foodResponse = await FoodService.GetFoodByIdAsync(FoodId);
        if (foodResponse is null)
        {
            _notFound = true;
            return;
        }

        Food = new UpdateFoodRequest
        {
            FoodId = foodResponse.FoodId,
            Name = foodResponse.Name,
            Category = foodResponse.Category,
            Calories = foodResponse.Calories,
            Protein = foodResponse.Protein,
            Fat = foodResponse.Fat,
            Carbs = foodResponse.Carbs,
            MealIds = foodResponse.Meals?.Select(m => m.MealId).ToList() ?? new List<int>()
        };
    }

    private Task OnSelectedMealsChanged(IEnumerable<int> values)
    {
        _selectedMealIds = values ?? Enumerable.Empty<int>();
        return Task.CompletedTask;
    }

    private async Task UpdateFood()
    {
        await FoodService.UpdateFoodAsync(Food);
        Snackbar.Add($"{Food.Name} updated successfully!", Severity.Success);
        NavigationManager.NavigateTo("/foods");
    }

    private void Home()
    {
        NavigationManager.NavigateTo("/foods");
    }

}
