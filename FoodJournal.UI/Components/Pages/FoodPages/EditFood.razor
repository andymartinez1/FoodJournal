@page "/foods/edit/{FoodId:int}"
@inject IFoodService FoodService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>

<div class="edit-page">
    <div class="page-header">
        <div>
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
                       Class="back-btn" OnClick="@Home">Foods
            </MudButton>
            <h1 class="page-title">Edit Food</h1>
            <p class="page-subtitle">Update the details for this food item</p>
        </div>
    </div>

    @if (_notFound)
    {
        <div class="not-found">
            <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Style="font-size:3rem;color:#94a3b8;"/>
            <p>Food item not found.</p>
            <MudButton Variant="Variant.Outlined" OnClick="@Home">Back to Foods</MudButton>
        </div>
    }
    else
    {
        <EditForm Model="Food" OnValidSubmit="UpdateFood">
            <DataAnnotationsValidator/>

            <div class="form-layout">
                <!-- Main details -->
                <div class="form-card">
                    <div class="form-section-title">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="section-icon"/>
                        Basic Info
                    </div>

                    <MudTextField Label="Food name"
                                  @bind-Value="Food.Name"
                                  For="@(() => Food.Name)"
                                  Variant="Variant.Outlined"
                                  Class="form-field"/>

                    <MudSelect T="string"
                               Label="Category"
                               @bind-Value="Food.Category"
                               For="@(() => Food.Category)"
                               Variant="Variant.Outlined"
                               Searchable="true"
                               Clearable="true"
                               Class="form-field">
                        @foreach (var category in _existingCategories)
                        {
                            <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int" Label="Appears in meals"
                               MultiSelection="true"
                               Variant="Variant.Outlined"
                               SelectedValues="_selectedMealIds"
                               SelectedValuesChanged="OnSelectedMealsChanged"
                               Class="form-field">
                        @foreach (var m in _meals)
                        {
                            <MudSelectItem Value="@m.Id">@m.Name (@m.MealType)</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <!-- Nutrition -->
                <div class="form-card">
                    <div class="form-section-title">
                        <MudIcon Icon="@Icons.Material.Outlined.LocalFireDepartment" Class="section-icon"/>
                        Nutrition
                    </div>

                    <div class="nutrition-grid">
                        <div class="nutrient-field cal-field">
                            <MudTextField Label="Calories (kcal)"
                                          @bind-Value="Food.Calories"
                                          For="@(() => Food.Calories)"
                                          Variant="Variant.Outlined"/>
                        </div>
                        <div class="nutrient-field prot-field">
                            <MudTextField Label="Protein (g)"
                                          @bind-Value="Food.Protein"
                                          For="@(() => Food.Protein)"
                                          Variant="Variant.Outlined"/>
                        </div>
                        <div class="nutrient-field fat-field">
                            <MudTextField Label="Fat (g)"
                                          @bind-Value="Food.Fat"
                                          For="@(() => Food.Fat)"
                                          Variant="Variant.Outlined"/>
                        </div>
                        <div class="nutrient-field carb-field">
                            <MudTextField Label="Carbs (g)"
                                          @bind-Value="Food.Carbs"
                                          For="@(() => Food.Carbs)"
                                          Variant="Variant.Outlined"/>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Close"
                               Class="cancel-btn" OnClick="@Home">
                        Cancel
                    </MudButton>
                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               Class="submit-btn">
                        Save Changes
                    </MudButton>
                </div>
            </div>
        </EditForm>
    }
</div>


@code {
    [Parameter] public int FoodId { get; set; }
    private IEnumerable<int> _selectedMealIds = Enumerable.Empty<int>();
    private List<Meal> _meals = new();
    private bool _notFound;
    private List<string> _existingCategories = new();
    private UpdateFoodRequest Food { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        _meals = await FoodService.GetAllMealsAsync();

        var foods = await FoodService.GetAllAsync();
        _existingCategories = foods
            .Select(f => f.Category)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c)
            .ToList()!;
    }

    protected override async Task OnParametersSetAsync()
    {
        _notFound = false;

        var foodResponse = await FoodService.GetByIdAsync(FoodId);
        if (foodResponse is null)
        {
            _notFound = true;
            return;
        }

        Food = new UpdateFoodRequest
        {
            FoodId = foodResponse.FoodId,
            Name = foodResponse.Name,
            Category = foodResponse.Category,
            Calories = foodResponse.Calories,
            Protein = foodResponse.Protein,
            Fat = foodResponse.Fat,
            Carbs = foodResponse.Carbs,
            MealIds = foodResponse.Meals?.Select(m => m.Id).ToList() ?? new List<int>()
        };
    }

    private Task OnSelectedMealsChanged(IEnumerable<int> values)
    {
        _selectedMealIds = values ?? Enumerable.Empty<int>();
        return Task.CompletedTask;
    }

    private async Task UpdateFood()
    {
        await FoodService.UpdateAsync(Food);
        Snackbar.Add($"{Food.Name} updated successfully!", Severity.Success);
        NavigationManager.NavigateTo("/foods");
    }

    private void Home()
    {
        NavigationManager.NavigateTo("/foods");
    }

}
