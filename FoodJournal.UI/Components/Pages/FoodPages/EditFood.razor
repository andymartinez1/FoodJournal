@page "/foods/edit/{FoodId:int}"
@using FoodJournal.ServiceContracts.DTOs.FoodDTOs
@inject IFoodService FoodService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>

@if (_loading)
{
    <p>Loading...</p>
}
else if (_notFound)
{
    <p>Not found.</p>
}
else
{
    <EditForm Model="Food" OnValidSubmit="UpdateFood">
        <DataAnnotationsValidator/>

        <MudGrid>
            <MudItem xs="12" sm="7">
                <MudCard>
                    <MudCardContent>
                        <MudTextField Label="Food name"
                                      @bind-Value="Food.Name"
                                      For="@(() => Food.Name)"/>

                        <MudSelect T="string"
                                   Label="Category"
                                   @bind-Value="Food.Category"
                                   For="@(() => Food.Category)"
                                   Searchable="true"
                                   Clearable="true">
                            @foreach (var category in _existingCategories)
                            {
                                <MudSelectItem T="string" Value="@category">@category</MudSelectItem>
                            }
                        </MudSelect>

                        <MudTextField Label="Calories" Class="mt-3"
                                      @bind-Value="Food.Calories"
                                      For="@(() => Food.Calories)"/>
                        <MudTextField Label="Protein(g)" Class="mt-3"
                                      @bind-Value="Food.Protein"
                                      For="@(() => Food.Protein)"/>
                        <MudTextField Label="Fat(g)" Class="mt-3"
                                      @bind-Value="Food.Fat"
                                      For="@(() => Food.Fat)"/>
                        <MudTextField Label="Carbs(g)" Class="mt-3"
                                      @bind-Value="Food.Carbs"
                                      For="@(() => Food.Carbs)"/>
                    </MudCardContent>

                    <MudCardActions>
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                                   Class="ml-auto" OnClick="@Home">
                            Cancel
                        </MudButton>

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled" Color="Color.Primary"
                                   Class="ml-auto">
                            Submit
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </EditForm>
}

@code {
    [Parameter] public int FoodId { get; set; }

    private bool _loading = true;
    private bool _notFound;
    private List<string> _existingCategories = new();
    private UpdateFoodRequest Food { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var foods = await FoodService.GetAllFoodAsync(); // or a dedicated "GetCategories" endpoint
        _existingCategories = foods
            .Select(f => f.Category)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c)
            .ToList()!;
    }

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _notFound = false;

        var foodResponse = await FoodService.GetFoodByIdAsync(FoodId);
        if (foodResponse is null)
        {
            _notFound = true;
            _loading = false;
            return;
        }

        Food = new UpdateFoodRequest
        {
            FoodId = foodResponse.FoodId,
            Name = foodResponse.Name,
            Category = foodResponse.Category,
            Calories = foodResponse.Calories,
            Protein = foodResponse.Protein,
            Fat = foodResponse.Fat,
            Carbs = foodResponse.Carbs,
            MealIds = foodResponse.Meals?.Select(m => m.MealId).ToList() ?? new List<int>()
        };

        _loading = false;
    }

    private async Task UpdateFood()
    {
        await FoodService.UpdateFoodAsync(Food);
        Snackbar.Add("Food Updated!", Severity.Success);
        NavigationManager.NavigateTo("/foods");
    }

    private void Home()
    {
        NavigationManager.NavigateTo("/foods");
    }

}
