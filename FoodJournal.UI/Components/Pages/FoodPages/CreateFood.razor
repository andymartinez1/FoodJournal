@page "/foods/create"
@using FoodJournal.Entities
@using FoodJournal.ServiceContracts.DTOs.FoodDTOs
@inject IFoodService FoodService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Create</PageTitle>

<EditForm method="post" Model="Food" OnValidSubmit="AddFood" FormName="createFood" Enhance>
    <DataAnnotationsValidator/>
    <MudGrid>
        <MudItem xs="12" sm="7">
            <MudCard>
                <MudCardContent>
                    <MudTextField Label="Food name" HelperText="Max. 8 characters"
                                  @bind-Value="Food.Name" For="@(() => Food.Name)"/>
                    <MudSelect Label="Category" Class="mt-3"
                               @bind-Value="Food.Category" For="@(() => Food.Category)">
                        @foreach (FoodCategory category in Enum.GetValues(typeof(FoodCategory)))
                        {
                            <MudSelectItem value="@category">@category</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="int" Label="Appears in meals" Class="mt-3" MultiSelection="true"
                               SelectedValues="_selectedMealIds" SelectedValuesChanged="OnSelectedMealsChanged">
                        @foreach (var m in _meals)
                        {
                            <MudSelectItem Value="@m.MealId">@m.Name (@m.MealType)</MudSelectItem>
                        }
                    </MudSelect>

                    <MudTextField Label="Calories" HelperText="" Class="mt-3"
                                  @bind-Value="Food.Calories" For="@(() => Food.Calories)"/>
                    <MudTextField Label="Protein(g)" HelperText="" Class="mt-3"
                                  @bind-Value="Food.Protein" For="@(() => Food.Protein)"/>
                    <MudTextField Label="Fat(g)" HelperText="" Class="mt-3"
                                  @bind-Value="Food.Fat" For="@(() => Food.Fat)"/>
                    <MudTextField Label="Carbs(g)" HelperText="" Class="mt-3"
                                  @bind-Value="Food.Carbs" For="@(() => Food.Carbs)"/>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                               Class="ml-auto" OnClick="@Home">Cancel
                    </MudButton>
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               Class="ml-auto">Submit
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
</EditForm>


@code {
    [SupplyParameterFromForm] private AddFoodRequest Food { get; set; } = new();
    private List<Meal> _meals = new();
    private IEnumerable<int> _selectedMealIds = Enumerable.Empty<int>();
    bool success;
    string[] errors = Array.Empty<string>();

    protected override async Task OnInitializedAsync()
    {
        Food = new AddFoodRequest();
        _meals = await FoodService.GetAllMealsAsync();
    }

    private Task OnSelectedMealsChanged(IEnumerable<int> values)
    {
        _selectedMealIds = values ?? Enumerable.Empty<int>();
        return Task.CompletedTask;
    }

    private async Task AddFood()
    {
        Food.MealIds = _selectedMealIds?.ToList() ?? new List<int>();

        await FoodService.AddFoodAsync(Food);

        NavigationManager.NavigateTo("/foods");
    }

    private void Home()
    {
        NavigationManager.NavigateTo("/foods");
    }

}
