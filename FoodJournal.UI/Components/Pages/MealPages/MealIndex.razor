@page "/meals"
@inject IMealService MealService
@inject IReportService ReportService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@rendermode InteractiveServer

<PageTitle>Meals</PageTitle>

<div class="meals-page">
    <div class="page-header">
        <div>
            <h1 class="page-title">Meals</h1>
            <p class="page-subtitle">Browse and manage your meal collection</p>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Class="add-btn"
                   OnClick="Create">
            Add Meal
        </MudButton>
    </div>

    <div class="filter-bar">
        <MudTextField T="string" Value="@NameSearch"
                      ValueChanged="@(v => OnSearchChanged(nameof(NameSearch), v))"
                      ValueExpression="(() => NameSearch)"
                      Placeholder="Search meals..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true"
                      Class="search-field"/>
        <MudSelect T="MealType?"
                   ValueChanged="@(value => OnSearchChanged(nameof(MealTypeSearch), value.ToString()))"
                   Placeholder="Meal type"
                   Variant="Variant.Outlined"
                   Class="type-select">
            @foreach (MealType type in Enum.GetValues(typeof(MealType)))
            {
                <MudSelectItem T="MealType?" Value="@type">@type</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Outlined" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.FilterAltOff"
                   OnClick="@ClearFilters"
                   Class="filter-btn">
            Clear
        </MudButton>
    </div>

    @if (_filteredMeals.Count == 0)
    {
        <div class="empty-state">
            <MudIcon Icon="@Icons.Material.Outlined.SearchOff" Class="empty-icon"/>
            <p class="empty-title">No meals found</p>
            <p class="empty-sub">Try adjusting your filters or add a new meal.</p>
        </div>
    }
    else
    {
        <div class="results-bar">
            <span class="results-count">
                Showing @((_currentPage - 1) * _pageSize + 1)–@(Math.Min(_currentPage * _pageSize, _filteredMeals.Count)) of @_filteredMeals.Count meals
            </span>
            <MudSelect T="int" Value="@_pageSize" ValueChanged="OnPageSizeChanged"
                       Variant="Variant.Outlined" Dense="true" Class="page-size-select">
                <MudSelectItem Value="6">6 per page</MudSelectItem>
                <MudSelectItem Value="9">9 per page</MudSelectItem>
                <MudSelectItem Value="12">12 per page</MudSelectItem>
                <MudSelectItem Value="24">24 per page</MudSelectItem>
            </MudSelect>
        </div>

        <MudGrid>
            @foreach (var meal in PagedMeals)
            {
                <MealCardComponent MealResponse="meal" OnViewClicked="TrackMealConsumption" OnEditClicked="Edit"/>
            }
        </MudGrid>

        @if (TotalPages > 1)
        {
            <div class="pagination-bar">
                <MudPagination Count="@TotalPages" @bind-Selected="_currentPage"
                               Color="Color.Primary" BoundaryCount="1" MiddleCount="3"
                               ShowFirstButton="true" ShowLastButton="true"
                               Class="pagination"/>
            </div>
        }
    }
</div>



@code {
    public string NameSearch { get; set; } = "";
    public string MealTypeSearch { get; set; } = "";

    private List<MealResponse> _meals { get; set; }
    private List<MealResponse> _filteredMeals { get; set; }

    private int _currentPage = 1;
    private int _pageSize = 9;

    private int TotalPages => _filteredMeals.Count == 0
        ? 1
        : (int)Math.Ceiling((double)_filteredMeals.Count / _pageSize);

    private IEnumerable<MealResponse> PagedMeals =>
        _filteredMeals.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);

    protected override async Task OnInitializedAsync()
    {
        _meals = await MealService.GetAllAsync();
        _filteredMeals = _meals;
    }

    private void OnSearchChanged(string searchBy, string value)
    {
        if (searchBy == nameof(NameSearch)) NameSearch = value;
        else if (searchBy == nameof(MealTypeSearch)) MealTypeSearch = value;
        FilterItems();
        StateHasChanged();
    }

    private void FilterItems()
    {
        _filteredMeals = _meals
            .Where(f => string.IsNullOrWhiteSpace(NameSearch) ||
                        f.Name.Contains(NameSearch, StringComparison.OrdinalIgnoreCase))
            .Where(f => string.IsNullOrWhiteSpace(MealTypeSearch) ||
                        (f.MealType.ToString() ?? string.Empty).Contains(MealTypeSearch, StringComparison.OrdinalIgnoreCase))
            .ToList();
        _currentPage = 1;
    }

    private void ClearFilters()
    {
        NameSearch = string.Empty;
        MealTypeSearch = string.Empty;
        FilterItems();
        StateHasChanged();
    }

    private void OnPageSizeChanged(int size)
    {
        _pageSize = size;
        _currentPage = 1;
        StateHasChanged();
    }

    private void Create()
    {
        NavigationManager.NavigateTo("/meals/create");
    }

    private async Task TrackMealConsumption(int mealId)
    {
        await ReportService.LogMealConsumptionAsync(mealId, DateOnly.FromDateTime(DateTime.Today));
        Snackbar.Add("Meal consumption tracked.", Severity.Success);
    }

    private void Edit(int mealId)
    {
        NavigationManager.NavigateTo($"/meals/edit/{mealId}");
    }

}
