<MudItem xs="12" sm="6" md="4">
    <MudCard Class="meal-card">
        <div class="image-wrap">
            <MudImage Src="@GetImagePath()"
                      Alt="@MealResponse.Name"
                      Fluid="true"
                      Class="meal-image"/>
            <div class="favorite-badge">
                <MudIcon
                    Icon="@(MealResponse.IsFavorite ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                    Color="@(MealResponse.IsFavorite ? Color.Error : Color.Default)"
                    Style="font-size:1.1rem;"/>
            </div>
        </div>

        <MudCardContent Class="card-body">
            <MudStack Spacing="2">
                <div>
                    <MudText Typo="Typo.h6" Class="meal-title">@MealResponse.Name</MudText>
                    <MudText Typo="Typo.body2" Class="meal-description">@MealResponse.Description</MudText>
                </div>

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                             Class="type-chip">
                        @MealResponse.MealType
                    </MudChip>
                    <span class="meta-text">
                        <MudIcon Icon="@Icons.Material.Outlined.Replay"
                                 Style="font-size:0.85rem;vertical-align:middle;"/> @MealResponse.TimesEaten×
                    </span>
                    <span class="meta-text">
                        <MudIcon Icon="@Icons.Material.Outlined.CalendarToday"
                                 Style="font-size:0.85rem;vertical-align:middle;"/> @MealResponse.LastDayEaten
                    </span>
                </MudStack>

                <div class="nutrition-grid">
                    <div class="nutrient cal">
                        <span class="nutrient-val">@MealResponse.Calories</span>
                        <span class="nutrient-lbl">kcal</span>
                    </div>
                    <div class="nutrient prot">
                        <span class="nutrient-val">@MealResponse.Protein g</span>
                        <span class="nutrient-lbl">protein</span>
                    </div>
                    <div class="nutrient fat">
                        <span class="nutrient-val">@MealResponse.Fat g</span>
                        <span class="nutrient-lbl">fat</span>
                    </div>
                    <div class="nutrient carb">
                        <span class="nutrient-val">@MealResponse.Carbs g</span>
                        <span class="nutrient-lbl">carbs</span>
                    </div>
                </div>

                <div>
                    <p class="ingredients-label">Ingredients</p>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var ingredient in MealResponse.Ingredients)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                                     Class="ingredient-chip">
                                @ingredient.Name
                            </MudChip>
                        }
                    </MudStack>
                </div>
            </MudStack>
        </MudCardContent>

        <MudCardActions Class="card-actions" Style="gap: 8px;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Class="action-btn">View
            </MudButton>
            <MudButton Variant="Variant.Outlined" Size="Size.Small" Class="action-btn">Edit</MudButton>
        </MudCardActions>
    </MudCard>
</MudItem>


@code {
    [Parameter] [EditorRequired] public MealResponse MealResponse { get; set; } = default!;

    private string GetImagePath()
    {
        return string.IsNullOrWhiteSpace(MealResponse.ImagePath)
            ? ImagePathHelper.GetMealImagePath(MealResponse.Name)
            : MealResponse.ImagePath;
    }
}