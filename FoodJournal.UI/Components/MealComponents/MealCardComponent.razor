@using FoodJournal.Helpers
@using FoodJournal.ServiceContracts.DTOs.MealDTOs
<MudItem xs="12" sm="6" md="4">
    <MudCard>
        <MudCardContent>
            <MudStack Spacing="1">
                <MudImage Src="@ImagePathHelper.GetImagePath(MealResponse.Name)" Alt="@MealResponse.Name"
                          Fluid="true"></MudImage>
                <MudText Typo="Typo.h6" Class="meal-title">@MealResponse.Name</MudText>
                <MudText Typo="Typo.body2" Class="meal-description">@MealResponse.Description</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                         Variant="Variant.Text">@MealResponse.MealType.ToString()</MudChip>

                <MudDivider Class="my-1"/>

                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
                        Calories: @MealResponse.Calories</MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
                        Protein: @MealResponse.Protein g
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">
                        Fat: @MealResponse.Fat g
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success">
                        Carbs: @MealResponse.Carbs g
                    </MudChip>
                </MudStack>

                <MudDivider Class="my-1"/>

                <MudText Typo="Typo.subtitle2" Class="mt-2">Ingredients</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var ingredient in MealResponse.Ingredients)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Color="Color.Secondary">@ingredient.Name</MudChip>
                    }
                </MudStack>
            </MudStack>
        </MudCardContent>
    </MudCard>
</MudItem>


@code {
    [Parameter] public MealResponse MealResponse { get; set; }
}