<MudDialog>
    <TitleContent>
        <div class="delete-title">
            <MudIcon Icon="@Icons.Material.Outlined.DeleteOutline" Class="delete-icon"/>
            <span>Delete Food?</span>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="delete-body">
            <p class="delete-warning">
                Are you sure you want to delete <strong>@Food.Name</strong>? This action cannot be undone.
            </p>

            <div class="food-summary">
                <div class="summary-row">
                    <span class="summary-label">Name</span>
                    <span class="summary-value">@Food.Name</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Category</span>
                    <span class="summary-value">@Food.Category</span>
                </div>
                <div class="nutrition-grid">
                    <div class="nutrient cal">
                        <span class="nutrient-val">@Food.Calories</span>
                        <span class="nutrient-lbl">kcal</span>
                    </div>
                    <div class="nutrient prot">
                        <span class="nutrient-val">@Food.Protein g</span>
                        <span class="nutrient-lbl">protein</span>
                    </div>
                    <div class="nutrient fat">
                        <span class="nutrient-val">@Food.Fat g</span>
                        <span class="nutrient-lbl">fat</span>
                    </div>
                    <div class="nutrient carb">
                        <span class="nutrient-val">@Food.Carbs g</span>
                        <span class="nutrient-lbl">carbs</span>
                    </div>
                </div>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel" Class="dialog-btn">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteForever"
                   OnClick="Delete" Class="dialog-btn">
            Delete
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }
    [Parameter] public FoodResponse Food { get; set; }

    private void Delete()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

}

