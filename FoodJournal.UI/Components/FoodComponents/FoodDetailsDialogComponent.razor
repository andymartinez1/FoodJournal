<MudDialog>
    <TitleContent>
        <div class="details-title">
            <MudIcon Icon="@Icons.Material.Outlined.Info" Class="title-icon"/>
            <span>@Food.Name</span>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="details-body">

            <div class="detail-row">
                <span class="detail-label">Name</span>
                <span class="detail-value">@Food.Name</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Category</span>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Color="Color.Primary" Class="cat-chip">@Food.Category</MudChip>
            </div>

            <div class="nutrition-grid">
                <div class="nutrient cal">
                    <span class="nutrient-val">@Food.Calories</span>
                    <span class="nutrient-lbl">kcal</span>
                </div>
                <div class="nutrient prot">
                    <span class="nutrient-val">@Food.Protein g</span>
                    <span class="nutrient-lbl">protein</span>
                </div>
                <div class="nutrient fat">
                    <span class="nutrient-val">@Food.Fat g</span>
                    <span class="nutrient-lbl">fat</span>
                </div>
                <div class="nutrient carb">
                    <span class="nutrient-val">@Food.Carbs g</span>
                    <span class="nutrient-lbl">carbs</span>
                </div>
            </div>

            <div class="meals-section">
                <p class="meals-label">Appears in meals</p>
                @if (!Food.Meals.Any())
                {
                    <p class="no-meals">Not used in any meals yet.</p>
                }
                else
                {
                    <div class="meals-list">
                        @foreach (var meal in Food.Meals)
                        {
                            <div class="meal-row">
                                <span class="meal-name">@meal.Name</span>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                         Color="Color.Default" Class="meal-type-chip">@meal.MealType</MudChip>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="@(() => MudDialog.Cancel())"
                   Class="close-btn">Close
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public FoodResponse Food { get; set; } = default!;
}
